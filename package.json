{
  "name": "mcp-guardian",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -b && pnpm --filter @mcp-guardian/web typecheck",
    "test": "vitest run && pnpm --filter @mcp-guardian/web test",
    "test:e2e": "pnpm --filter @mcp-guardian/web test:e2e",
    "build": "tsc -b && pnpm --filter @mcp-guardian/web build",
    "build:pages": "tsc -b && pnpm --filter @mcp-guardian/web build:pages",
    "dev:gateway": "pnpm --filter @mcp-guardian/gateway dev",
    "dev:web": "pnpm --filter @mcp-guardian/web dev",
    "guardian": "node ./packages/gateway/dist/cli.js",
    "install:mcp": "node ./packages/gateway/dist/cli.js install"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.3",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^3.2.4"
  }
}
